{
  "version": 2,
  "functions": {
    "api/webhook.py": {
      "maxDuration": 10
    },
    "api/ping.py": {
      "maxDuration": 5
    }
  },
  "rewrites": [
    { "source": "/api/webhook", "destination": "/api/webhook.py" },
    { "source": "/api/ping",    "destination": "/api/ping.py" },
    { "source": "/",            "destination": "/public/index.html" },
    { "source": "/index.html",  "destination": "/public/index.html" }
  ]
}
